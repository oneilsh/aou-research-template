.venv/
__pycache__/
*.py[cod]
.pytest_cache/
.coverage
.ruff_cache/
.DS_Store
.ipynb_checkpoints/

# Python build / packaging artifacts (regenerated by `make install`/`make build`)
*.egg-info/
.eggs/
build/
dist/

# Secrets and per-workspace env
.env
.env.*
!.env.example
.workspace_env

# Run artifacts and local synthetic data (never committed)
experiments/**/runs/
data/

# Allow tiny synthetic test fixtures only
!**/tests/data/

# Agent-harness scratch — never useful in a template copy.
# Note: .claude/settings.json IS committed (shared, safe permission allowlist);
# only personal settings and per-session scratch are ignored here. Users remain
# free to commit their own .claude/agents, skills, and commands.
.claude/settings.local.json
.claude/handoffs/
.claude/plans/
.superpowers/
